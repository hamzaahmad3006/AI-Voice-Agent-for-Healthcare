# ─── Copy this file to frontend/.env.local and fill in real values ───────────
# frontend/.env.local is gitignored — never commit real secrets.
#
# Next.js rules:
#   • NEXT_PUBLIC_* vars are exposed to the browser bundle — never put secrets here.
#   • Server-only vars (no NEXT_PUBLIC_ prefix) are available in Server Components
#     and API routes only.

# ─── Backend API ──────────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by browser and server components)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── LiveKit (used by browser for direct WebRTC connection, if needed) ─────────
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
