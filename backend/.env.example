# ─── Copy this file to backend/.env and fill in real values ──────────────────
# backend/.env is gitignored — never commit real secrets.

# ─── LiveKit ──────────────────────────────────────────────────────────────────
# LOCAL DEV (localhost) — start the server first:
#   docker run --rm -p 7880:7880 -p 7881:7881 -p 7882:7882/udp livekit/livekit-server --dev
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# PRODUCTION (LiveKit Cloud):
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your_livekit_api_key
# LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Groq (LLM — LLaMA 3.1 70B Versatile) ────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.1-70b-versatile

# ─── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── TTS ──────────────────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
CARTESIA_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite — zero setup):
DATABASE_URL=sqlite+aiosqlite:///./audit.db
# Production (PostgreSQL — swap this line):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_voice_agent

# ─── Redis (session store) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=1800

# ─── Mock flags (true = use in-memory mocks; false = call real backends) ──────
USE_MOCK_FHIR=true
USE_MOCK_TALKEHR=true
USE_MOCK_INSURANCE=true

# ─── External APIs (used only when USE_MOCK_* = false) ────────────────────────
FHIR_BASE_URL=
FHIR_API_KEY=
TALKEHR_BASE_URL=
TALKEHR_API_KEY=
INSURANCE_BASE_URL=
INSURANCE_API_KEY=

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Human fallback ───────────────────────────────────────────────────────────
HUMAN_FALLBACK_NUMBER=+1-800-000-0000
