# ─── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ─── Anthropic (LLM) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
LLM_MODEL=claude-sonnet-4-6

# ─── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ─── TTS ──────────────────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
CARTESIA_API_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=1800

# ─── Mock flags (set to false when using real backends) ───────────────────────
USE_MOCK_FHIR=true
USE_MOCK_TALKEHR=true
USE_MOCK_INSURANCE=true

# ─── External APIs (ignored while USE_MOCK_* = true) ─────────────────────────
FHIR_BASE_URL=
FHIR_API_KEY=
TALKEHR_BASE_URL=
TALKEHR_API_KEY=
INSURANCE_BASE_URL=
INSURANCE_API_KEY=

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Human fallback ───────────────────────────────────────────────────────────
HUMAN_FALLBACK_NUMBER=+1-800-000-0000
